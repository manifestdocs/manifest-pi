{
  "name": "@manifestdocs/pi",
  "version": "2.0.0",
  "description": "Manifest integration for Pi coding agent — feature-driven development tools",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "manifest",
    "feature-management",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/manifestdocs/manifest-pi.git"
  },
  "files": ["dist", "extensions", "skills", "prompts", "package.json"],
  "pi": {
    "extensions": [
      "extensions/feature-workflow.ts"
    ],
    "skills": [
      "skills/*.md"
    ],
    "prompts": [
      "prompts/manifest.md"
    ]
  },
  "scripts": {
    "generate:content": "node ./scripts/generate-content.mjs",
    "build": "node ./scripts/generate-content.mjs && tsc",
    "test": "node ./scripts/generate-content.mjs && vitest",
    "test:run": "node ./scripts/generate-content.mjs && vitest run",
    "check": "node ./scripts/generate-content.mjs && tsc --noEmit"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "^0.53.0",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "^0.34.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {}
}
